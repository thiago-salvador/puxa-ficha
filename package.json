{
  "name": "puxa-ficha",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:clean": "rm -rf .next && next dev --turbopack",
    "dev:raw": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "test": "tsx --test tests/**/*.test.ts",
    "test:visual": "playwright test",
    "test:visual:mobile": "playwright test --project=mobile",
    "test:visual:quiz": "playwright test tests/visual/quiz.spec.ts",
    "test:visual:quiz:mobile": "playwright test --project=mobile tests/visual/quiz.spec.ts",
    "test:visual:quiz-og": "npm run build && playwright test -c playwright.quiz-og.config.ts",
    "check:quiz-votacoes": "tsx scripts/check-quiz-votacoes-chave.ts",
    "check:scripts": "tsc --project tsconfig.scripts.json",
    "smoke:runtime": "tsx scripts/smoke-check-runtime.ts",
    "smoke:criticos": "tsx scripts/smoke-check-criticos.ts",
    "smoke:camara-incremental-db": "tsx scripts/smoke-camara-incremental-db.ts",
    "audit:completude": "tsx scripts/audit-completude.ts",
    "audit:completude:gate": "tsx scripts/check-completude-gate.ts",
    "audit:factual": "tsx scripts/audit-factual.ts",
    "audit:factual:gate": "tsx scripts/check-audit-gate.ts",
    "audit:factual:diff": "tsx scripts/audit-factual-diff.ts",
    "audit:release-verify": "tsx scripts/release-verify.ts",
    "audit:release-verify:partial": "tsx scripts/release-verify.ts --mode partial",
    "audit:release-verify:prod": "sh -c 'if [ -z \"$VERIFY_URL\" ]; then echo \"Defina VERIFY_URL (ex: https://puxaficha.com.br)\"; exit 1; fi; tsx scripts/release-verify.ts'",
    "audit:publish:dry-run": "tsx scripts/set-publicavel-from-audit.ts --dry-run",
    "audit:dossiers": "tsx scripts/build-candidate-dossiers.ts",
    "persist:sq": "tsx scripts/persist-sq-candidato.ts",
    "sync:mock:assertions": "tsx scripts/sync-mock-from-assertions.ts",
    "sync:structured:mock": "tsx scripts/sync-curated-structured-from-mock.ts",
    "audit:publish": "tsx scripts/audit-factual.ts && tsx scripts/check-audit-gate.ts --max-blocked 0 --min-assertions 144 --min-curated auto",
    "data:backfill-pontos-data-referencia": "tsx scripts/backfill-pontos-atencao-data-referencia.ts",
    "data:backfill-pontos-data-referencia:dry-run": "tsx scripts/backfill-pontos-atencao-data-referencia.ts --dry-run",
    "data:fix-pontos-timeline-gaps": "tsx scripts/fix-pontos-timeline-gaps.ts",
    "data:fix-pontos-timeline-gaps:dry-run": "tsx scripts/fix-pontos-timeline-gaps.ts --dry-run",
    "data:recalc-pontos-data-referencia": "tsx scripts/recalc-pontos-data-referencia.ts",
    "data:recalc-pontos-data-referencia:dry-run": "tsx scripts/recalc-pontos-data-referencia.ts --dry-run"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@supabase/supabase-js": "^2.100.1",
    "@tanstack/react-virtual": "^3.13.23",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.14.2",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.7.0",
    "next": "15.5.14",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "agent-react-devtools": "^0.3.0",
    "csv-parse": "^6.2.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.14",
    "playwright": "^1.59.1",
    "react-devtools-core": "^7.0.1",
    "shadcn": "^4.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
