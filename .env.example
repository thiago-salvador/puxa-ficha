# Supabase - app server/read-only
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Supabase - ingest/scripts privileged
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Compat legada durante migracao. O app deve preferir as vars server-side acima.
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Preview interno
# PF_PREVIEW_TOKEN=defina-um-token-longo-e-aleatorio-com-pelo-menos-24-caracteres

# Rotas internas protegidas em preview
# PF_INTERNAL_TOKEN=defina-um-token-longo-e-aleatorio

# Host proprio com `next start` em HTTPS: forcar upgrade-insecure-requests + HSTS no next.config (na Vercel, VERCEL=1 ja basta)
# PF_FORCE_PRODUCTION_SECURITY_HEADERS=1

# Metadata social
# NEXT_PUBLIC_X_HANDLE=@puxaficha

# Integracoes externas
# INSTAGRAM_APP_ID=936619743392459

# Portal da Transparencia (opcional)
# TRANSPARENCIA_API_KEY=

# IA - Fase 2 (opcional)
# ANTHROPIC_API_KEY=sk-ant-...
# MARITACA_API_KEY=

# Quiz: salt para hash de IP em links curtos (/api/quiz/short-link). Defina em produção.
# PF_QUIZ_SHORT_LINK_SALT=

# Alertas por email (MVP)
# RESEND_API_KEY=re_...
# CRON_SECRET=defina-um-token-longo-e-aleatorio
# PF_ALERTS_FROM_EMAIL="Puxa Ficha <alertas@puxaficha.com.br>"
# PF_ALERTS_TOKEN_SALT=defina-um-salt-longo-e-aleatorio
# PF_ALERTS_IP_SALT=defina-um-salt-longo-e-aleatorio
# PF_ALERTS_TOKEN_ENCRYPTION_KEY=64-caracteres-hex-para-aes-256-gcm
